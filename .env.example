# ========================================
# Clinicease4vet 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# ========================================

# MySQL 数据库 (backend/backend_local 使用 SQLite 无需配置)
MYSQL_HOST=127.0.0.1
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=max_hospitals

# JWT 密钥 (生产环境请使用随机字符串)
JWT_SECRET_KEY=change-me-to-a-random-string

# DeepSeek AI (必需 - 在 https://platform.deepseek.com 获取)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_MODEL=deepseek-chat

# 科大讯飞语音转写 (可选 - 在 https://console.xfyun.cn 获取)
IFLYTEK_APP_ID=your_iflytek_app_id
IFLYTEK_API_KEY=your_iflytek_api_key
IFLYTEK_API_SECRET=your_iflytek_api_secret
